---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Salon · Maja Willard">
<main class="salon">
  <a class="skip" href="/notatnik/">skip → notatnik</a>

  <div class="salon-head">
    <div class="row">
      <span>● seans nr 7</span>
      <span>warszawa · mmxxvi</span>
      <span>wstęp wolny ●</span>
    </div>
    <h1 class="display">Salon<br/><em>spirytystyczny.</em></h1>
    <div class="tag">A séance with Maja. Pick a card; the card picks a way in.</div>
    <div class="salon-instr">↓  draw a card  ↓</div>
  </div>

  <div class="seance-ring">
    <div class="seance-core">
      <div class="glyph">M·W</div>
      <div class="lbl">est. mmxxv</div>
    </div>
  </div>

  <div class="tarot-fan">
    <a class="tarot-card" href="/#akt-i">
      <span class="roman">I</span>
      <div class="glyph">☉</div>
      <div class="name">The Show</div>
      <div class="sub">plakat · about</div>
      <span class="roman br">I</span>
    </a>
    <a class="tarot-card" href="/notatnik/">
      <span class="roman">II</span>
      <div class="glyph">✶</div>
      <div class="name">The Science</div>
      <div class="sub">notatnik · cv · pubs</div>
      <span class="roman br">II</span>
    </a>
    <a class="tarot-card" href="/#akt-v">
      <span class="roman">III</span>
      <div class="glyph">❦</div>
      <div class="name">The Atelier</div>
      <div class="sub">paintings · drawings</div>
      <span class="roman br">III</span>
    </a>
    <a class="tarot-card" href="/#akt-iv">
      <span class="roman">IV</span>
      <div class="glyph">𓃠</div>
      <div class="name">The Cats</div>
      <div class="sub">koty · weekly</div>
      <span class="roman br">IV</span>
    </a>
    <a class="tarot-card" href="mailto:mayaowillard@gmail.com">
      <span class="roman">V</span>
      <div class="glyph">✉</div>
      <div class="name">The Letter</div>
      <div class="sub">kontakt</div>
      <span class="roman br">V</span>
    </a>
  </div>

  <div class="salon-foot">
    <span>● shuffle</span>
    <span>"remember it's all in your head"</span>
    <span>mw mmxxvi ●</span>
  </div>
</main>
</BaseLayout>
